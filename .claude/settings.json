{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm test*)",
      "Bash(npx jest*)",
      "Bash(npx tsc*)",
      "Bash(npx expo*)",
      "Bash(npm start*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git checkout*)",
      "Bash(git show*)",
      "Bash(git remote -v*)"
    ],
    "deny": [
      "Bash(npm publish*)",
      "Bash(expo publish*)",
      "Bash(eas submit*)"
    ]
  }
}

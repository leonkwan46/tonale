{
  "expo": {
    "name": "Tonale",
    "slug": "tonale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tonale",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lkstudio.tonale",
      "infoPlist": {
        "CFBundleDisplayName": "Tonalè"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.lkstudio.tonale",
      "displayName": "Tonalè"
    },
    "assetBundlePatterns": [
      "assets/fonts/*"
    ],
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-asset",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "lk-studio-59"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.476539409264-mo9lggoj2jgjkos2fu4cnq2ps1fqb077"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
